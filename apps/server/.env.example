# 服务端口（Docker 容器内监听端口，Nginx 反代到 3001）
PORT=3001

# 数据库连接（SQLite 开发示例，生产可替换为 PostgreSQL）
DATABASE_URL="file:./dev.db"

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# 可选：Redis 密码（如使用云 Redis）
# REDIS_PASSWORD=

# 可选：微信小程序 AppID（用于微信登录等能力）
# WEIXIN_APP_ID=

# 可选：微信小程序 AppSecret
# WEIXIN_APP_SECRET=

# 可选：阿里云 OSS / 腾讯云 COS（语音文件存储）
# OSS_ENDPOINT=
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=
