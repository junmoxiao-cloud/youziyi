/**app.wxss**/
page {
  background-color: #f7f5f0;
  color: #2b2d2f;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 36rpx;
  line-height: 1.6;
  min-height: 100vh;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.container {
  display: flex;
  flex-direction: column;
  padding: 32rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

/* 适老化排版 */
.yz-title {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.3;
  color: #2b2d2f;
}

.yz-subtitle {
  font-size: 36rpx;
  line-height: 1.5;
  color: #5a5c5f;
}

.yz-section-title {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
  color: #2b2d2f;
}

/* 卡片容器 */
.yz-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(43, 45, 47, 0.06);
  box-sizing: border-box;
}

/* 大按钮 */
.yz-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 120rpx;
  padding: 24rpx 40rpx;
  font-size: 44rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  box-sizing: border-box;
}

.yz-btn::after {
  border: none;
}

.yz-btn-primary {
  background-color: #3ba88e;
  color: #ffffff;
}

.yz-btn-primary:active {
  background-color: #329178;
}

/* 大输入框 */
.yz-input {
  width: 100%;
  min-height: 100rpx;
  padding: 24rpx 28rpx;
  font-size: 40rpx;
  color: #2b2d2f;
  background-color: #ffffff;
  border: 2rpx solid #e8e6e1;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.yz-input::placeholder {
  color: #a8a6a1;
}

/* 大点击热区与间距 */
.yz-tap-area {
  min-width: 96rpx;
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.yz-safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.yz-mt-16 { margin-top: 16rpx; }
.yz-mt-24 { margin-top: 24rpx; }
.yz-mt-32 { margin-top: 32rpx; }
.yz-mb-16 { margin-bottom: 16rpx; }
.yz-mb-24 { margin-bottom: 24rpx; }
.yz-mb-32 { margin-bottom: 32rpx; }
.yz-gap-16 { gap: 16rpx; }
.yz-gap-24 { gap: 24rpx; }
