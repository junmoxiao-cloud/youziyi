.onboarding-container {
  padding-top: 48rpx;
  padding-bottom: 64rpx;
}

.onboarding-header {
  margin-bottom: 48rpx;
}

.onboarding-title {
  display: block;
  margin-bottom: 24rpx;
  color: #2b2d2f;
}

.onboarding-subtitle {
  display: block;
  color: #5a5c5f;
  white-space: pre-line;
}

.onboarding-section {
  margin-bottom: 32rpx;
}

.onboarding-section-title {
  display: block;
  margin-bottom: 24rpx;
}

.onboarding-hint {
  display: block;
  font-size: 32rpx;
  color: #5a5c5f;
  margin-bottom: 24rpx;
}

.onboarding-input {
  width: 100%;
}

.city-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.city-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 120rpx;
  padding: 24rpx;
  background-color: #ffffff;
  border: 4rpx solid #e8e6e1;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.city-item-active {
  background-color: #eaf7f4;
  border-color: #3ba88e;
}

.city-item-active .city-name {
  color: #3ba88e;
}

.city-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #2b2d2f;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.metric-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 180rpx;
  padding: 24rpx;
  background-color: #ffffff;
  border: 4rpx solid #e8e6e1;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.metric-item-active {
  background-color: #eaf7f4;
  border-color: #3ba88e;
}

.metric-item-required {
  border-style: dashed;
}

.metric-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.metric-label {
  font-size: 36rpx;
  font-weight: 600;
  color: #2b2d2f;
}

.metric-item-active .metric-label {
  color: #3ba88e;
}

.onboarding-submit {
  width: 100%;
  margin-top: 16rpx;
}

.onboarding-submit-disabled {
  opacity: 0.5;
}
