.profile-container {
  padding-top: 24rpx;
  padding-bottom: 64rpx;
}

.profile-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.profile-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #2b2d2f;
}

.back-btn {
  width: 96rpx;
}

.back-btn.placeholder {
  visibility: hidden;
}

.back-icon {
  font-size: 48rpx;
  color: #2b2d2f;
}

.profile-section {
  margin-bottom: 32rpx;
}

.profile-section-title {
  display: block;
  margin-bottom: 24rpx;
}

.profile-input {
  width: 100%;
}

.profile-hint {
  display: block;
  font-size: 32rpx;
  color: #5a5c5f;
  margin-top: 16rpx;
  line-height: 1.5;
}

.city-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.city-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 120rpx;
  padding: 24rpx;
  background-color: #ffffff;
  border: 4rpx solid #e8e6e1;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.city-item-active {
  background-color: #eaf7f4;
  border-color: #3ba88e;
}

.city-item-active .city-name {
  color: #3ba88e;
}

.city-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #2b2d2f;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.metric-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 180rpx;
  padding: 24rpx;
  background-color: #ffffff;
  border: 4rpx solid #e8e6e1;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.metric-item-active {
  background-color: #eaf7f4;
  border-color: #3ba88e;
}

.metric-item-required {
  border-style: dashed;
}

.metric-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.metric-label {
  font-size: 36rpx;
  font-weight: 600;
  color: #2b2d2f;
}

.metric-item-active .metric-label {
  color: #3ba88e;
}

.profile-save-btn {
  width: 100%;
  margin-top: 16rpx;
}

.profile-save-btn[disabled] {
  opacity: 0.5;
}

.profile-logout-btn {
  width: 100%;
  margin-top: 32rpx;
  background-color: #ffffff;
  color: #c45c4a;
  border: 2rpx solid #e8e6e1;
}

.profile-logout-btn:active {
  background-color: #fdf6f5;
}

.profile-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
}

.profile-loading-text {
  font-size: 40rpx;
  color: #5a5c5f;
}
