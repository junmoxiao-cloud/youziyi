<view class="container role-select-container">
  <text class="yz-title role-select-title">欢迎回家，请告诉我您的身份</text>

  <view class="role-cards">
    <view
      class="yz-card role-card"
      bindtap="selectElder"
      hover-class="role-card-active"
      hover-stay-time="100"
    >
      <text class="role-icon">👴</text>
      <text class="role-label">我是长辈</text>
    </view>

    <view
      class="yz-card role-card"
      bindtap="selectChild"
      hover-class="role-card-active"
      hover-stay-time="100"
    >
      <text class="role-icon">👩</text>
      <text class="role-label">我是子女</text>
    </view>
  </view>
</view>
