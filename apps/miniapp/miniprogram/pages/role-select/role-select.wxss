.role-select-container {
  align-items: center;
  justify-content: center;
  padding-top: 80rpx;
  padding-bottom: 80rpx;
}

.role-select-title {
  text-align: center;
  margin-bottom: 80rpx;
}

.role-cards {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 32rpx;
  width: 100%;
}

.role-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 320rpx;
  min-width: 280rpx;
  min-height: 320rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 0;
  text-align: center;
  transition: transform 0.1s ease;
}

.role-card:active,
.role-card-active {
  background-color: #eaf7f4;
  transform: scale(0.98);
}

.role-icon {
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 32rpx;
}

.role-label {
  font-size: 44rpx;
  font-weight: 600;
  color: #2b2d2f;
}
