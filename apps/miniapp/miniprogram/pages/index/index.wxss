/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}
.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.container {
  padding: 30rpx;
}

.header {
  margin-bottom: 50rpx;
  text-align: center;
}

.title {
  font-size: 56rpx; /* 大字号 */
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 36rpx;
  color: #666666;
}

.section-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #000000;
  margin-bottom: 30rpx;
  display: block;
}

.mood-section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.mood-buttons {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.mood-btn {
  flex: 1;
  height: 120rpx;
  line-height: 120rpx;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  border-radius: 16rpx;
  padding: 0;
  margin: 0;
}

/* 高对比度颜色 */
.mood-btn.happy {
  background-color: #e64a19; /* 强烈的橙红 */
}
.mood-btn.calm {
  background-color: #1976d2; /* 强烈的蓝色 */
}
.mood-btn.sad {
  background-color: #455a64; /* 深灰蓝 */
}

.step-section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.step-input-wrapper {
  background: #f0f0f0;
  border-radius: 12rpx;
  padding: 20rpx;
}

.step-input {
  font-size: 48rpx;
  height: 80rpx;
  color: #000000;
}

.submit-section {
  margin-bottom: 40rpx;
}

.submit-btn {
  background-color: #2e7d32; /* 深绿色，高对比 */
  color: #ffffff;
  font-size: 48rpx;
  font-weight: bold;
  height: 120rpx;
  line-height: 120rpx;
  border-radius: 60rpx;
  width: 100%;
}

.nav-section {
  margin-top: 20rpx;
}

.nav-btn {
  background-color: #6a1b9a; /* 深紫色 */
  color: #ffffff;
  font-size: 48rpx;
  font-weight: bold;
  height: 110rpx;
  line-height: 110rpx;
  border-radius: 55rpx;
  width: 100%;
}
