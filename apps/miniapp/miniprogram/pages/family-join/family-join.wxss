.family-join-container {
  padding-top: 32rpx;
  padding-bottom: 64rpx;
}

.family-join-header {
  margin-bottom: 48rpx;
}

.family-join-header .yz-title {
  display: block;
  margin-bottom: 16rpx;
}

.family-join-header .yz-subtitle {
  display: block;
}

.mode-switch {
  display: flex;
  gap: 24rpx;
}

.mode-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 120rpx;
  padding: 24rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: #2b2d2f;
  background-color: #ffffff;
  border: 4rpx solid #e8e6e1;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.mode-btn-active {
  background-color: #eaf7f4;
  border-color: #3ba88e;
  color: #3ba88e;
}

.create-panel,
.join-panel {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.panel-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #2b2d2f;
}

.panel-desc {
  display: block;
  font-size: 34rpx;
  line-height: 1.5;
  color: #5a5c5f;
}

.code-display {
  background-color: #f7f5f0;
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
}

.code-label {
  display: block;
  font-size: 32rpx;
  color: #5a5c5f;
  margin-bottom: 12rpx;
}

.code-value {
  display: block;
  font-size: 64rpx;
  font-weight: 700;
  color: #3ba88e;
  letter-spacing: 16rpx;
}

.code-input {
  text-align: center;
  font-size: 48rpx;
  letter-spacing: 12rpx;
}

.code-input-error {
  border-color: #e04f4f;
  background-color: #fff5f5;
}

.error-text {
  display: block;
  font-size: 34rpx;
  color: #e04f4f;
}

.hint-card {
  background-color: #ffffff;
}

.hint-text {
  display: block;
  font-size: 32rpx;
  line-height: 1.5;
  color: #5a5c5f;
}

.family-state {
  text-align: center;
}

.state-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.state-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #3ba88e;
  margin-bottom: 16rpx;
}

.state-family-name {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #2b2d2f;
  margin-bottom: 8rpx;
}

.state-code {
  display: block;
  font-size: 34rpx;
  color: #5a5c5f;
  margin-bottom: 16rpx;
}

.state-message {
  display: block;
  font-size: 34rpx;
  color: #5a5c5f;
  margin-bottom: 32rpx;
}

.member-section {
  text-align: left;
  margin-top: 24rpx;
  margin-bottom: 32rpx;
}

.section-label {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #2b2d2f;
  margin-bottom: 16rpx;
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.member-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #f7f5f0;
  border-radius: 16rpx;
  padding: 24rpx;
}

.member-main {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.member-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #2b2d2f;
}

.member-city {
  font-size: 32rpx;
  color: #5a5c5f;
  margin-top: 8rpx;
}

.member-role-badge {
  font-size: 32rpx;
  font-weight: 600;
  color: #3ba88e;
  background-color: #eaf7f4;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
}

.family-enter-btn {
  width: 100%;
}

.family-join-container .yz-btn {
  width: 100%;
}
