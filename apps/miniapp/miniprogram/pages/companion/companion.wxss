.companion-container {
  padding-top: 24rpx;
  padding-bottom: 64rpx;
}

.scrollarea {
  height: 100vh;
}

/* 顶部头部 */
.companion-header {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(43, 45, 47, 0.06);
}

.header-main {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #2b2d2f;
  line-height: 1.3;
}

.header-date {
  font-size: 34rpx;
  color: #5a5c5f;
  margin-top: 12rpx;
}

.header-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.header-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  padding: 20rpx 32rpx;
  font-size: 38rpx;
  font-weight: 600;
  color: #2b2d2f;
  background-color: #f7f5f0;
  border-radius: 16rpx;
  border: none;
}

.header-btn::after {
  border: none;
}

.header-btn:active {
  background-color: #eceae5;
}

.header-btn-jade {
  color: #2d7a67;
  background-color: #eaf7f4;
}

.header-btn-jade:active {
  background-color: #d8f0ea;
}

.header-btn-blue {
  color: #2b5a8c;
  background-color: #eaf3fb;
}

.header-btn-blue:active {
  background-color: #d8e7f7;
}

/* 操作反馈 */
.action-message {
  background-color: #fff5f5;
  border: 2rpx solid #f5c6c6;
  color: #c0392b;
  font-size: 36rpx;
  line-height: 1.5;
}

/* 预警提示 */
.warning-toast {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(43, 45, 47, 0.08);
}

.warning-toast-level1 {
  background-color: #fdf6e3;
  border: 2rpx solid #f0d99a;
  color: #8c6a2b;
}

.warning-toast-level2 {
  background-color: #fff0ee;
  border: 2rpx solid #f5b7b1;
  color: #a93226;
}

.warning-toast-icon {
  font-size: 56rpx;
  line-height: 1;
}

.warning-toast-body {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.warning-toast-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.warning-toast-text {
  font-size: 34rpx;
  line-height: 1.5;
}

/* 区块标题 */
.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.section-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.section-dot-jade {
  background-color: #3ba88e;
  box-shadow: 0 0 12rpx rgba(59, 168, 142, 0.5);
}

.section-dot-cinnabar {
  background-color: #d25642;
  box-shadow: 0 0 12rpx rgba(210, 86, 66, 0.5);
}

.section-dot-blue {
  background-color: #4a90d9;
  box-shadow: 0 0 12rpx rgba(74, 144, 217, 0.5);
}

.section-dot-amber {
  background-color: #e5a23b;
  box-shadow: 0 0 12rpx rgba(229, 162, 59, 0.5);
}

/* 亲情温度计 */
.thermometer-card {
  text-align: center;
}

.thermometer-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.thermometer-circle {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.thermometer-warm {
  background: linear-gradient(135deg, #d4f3eb 0%, #eafaf6 100%);
  box-shadow: 0 12rpx 40rpx rgba(59, 168, 142, 0.2);
}

.thermometer-mild {
  background: linear-gradient(135deg, #fdf6e3 0%, #f9e8c0 100%);
  box-shadow: 0 12rpx 40rpx rgba(229, 192, 123, 0.25);
}

.thermometer-cold {
  background: linear-gradient(135deg, #ffecea 0%, #ffd6d1 100%);
  box-shadow: 0 12rpx 40rpx rgba(210, 86, 66, 0.2);
}

.thermometer-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  opacity: 0.25;
  animation: pulse-ring 2s ease-out infinite;
}

.thermometer-warm .thermometer-ring {
  background-color: #3ba88e;
}

.thermometer-mild .thermometer-ring {
  background-color: #e5a23b;
}

.thermometer-cold .thermometer-ring {
  background-color: #d25642;
}

@keyframes pulse-ring {
  0% {
    transform: scale(1);
    opacity: 0.25;
  }
  100% {
    transform: scale(1.15);
    opacity: 0;
  }
}

.thermometer-inner {
  position: relative;
  z-index: 1;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
}

.thermometer-status {
  font-size: 42rpx;
  font-weight: 700;
  color: #2b2d2f;
}

.thermometer-info {
  width: 100%;
  background-color: #f7f5f0;
  border-radius: 16rpx;
  padding: 24rpx;
}

.thermometer-label {
  display: block;
  font-size: 32rpx;
  color: #5a5c5f;
  margin-bottom: 8rpx;
}

.thermometer-duration {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #2b2d2f;
}

/* 同一片天空 */
.weather-grid {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.weather-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #ffffff 0%, #f7f5f0 100%);
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  border: 2rpx solid #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(43, 45, 47, 0.04);
}

.weather-card-label {
  font-size: 28rpx;
  color: #8a8c8f;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  margin-bottom: 12rpx;
}

.weather-card-city {
  font-size: 44rpx;
  font-weight: 700;
  color: #2b2d2f;
  margin-bottom: 16rpx;
  text-align: center;
}

.weather-card-icon {
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 16rpx;
}

.weather-card-desc {
  font-size: 34rpx;
  color: #5a5c5f;
  font-weight: 500;
  text-align: center;
}

.weather-hint {
  background-color: #f7f5f0;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #5a5c5f;
  line-height: 1.5;
}

/* 今日共享状态 */
.shared-status-body {
  background: linear-gradient(180deg, #ffffff 0%, #f7f5f0 100%);
  border-radius: 24rpx;
  padding: 28rpx;
  border: 2rpx solid #ffffff;
}

.shared-status-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.shared-target-label {
  display: block;
  font-size: 32rpx;
  color: #5a5c5f;
  margin-bottom: 8rpx;
}

.shared-status-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #2b2d2f;
}

.shared-mood-icon {
  font-size: 96rpx;
  line-height: 1;
}

.shared-metrics {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.metric-item {
  flex: 1;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(43, 45, 47, 0.04);
}

.metric-label {
  display: block;
  font-size: 30rpx;
  color: #5a5c5f;
  margin-bottom: 8rpx;
}

.metric-value {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #2b2d2f;
}

.shared-update-time {
  display: block;
  font-size: 30rpx;
  color: #8a8c8f;
}

/* 家庭故事接龙 */
.voice-empty {
  background-color: #f7f5f0;
  border-radius: 16rpx;
  padding: 40rpx 24rpx;
  text-align: center;
  font-size: 34rpx;
  color: #5a5c5f;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.voice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.voice-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #f7f5f0;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
}

.voice-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.voice-role-badge {
  flex-shrink: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #2d7a67;
  background-color: #eaf7f4;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
}

.voice-time {
  font-size: 34rpx;
  color: #5a5c5f;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.voice-duration {
  flex-shrink: 0;
  font-size: 34rpx;
  font-weight: 600;
  color: #2b2d2f;
}

.voice-action-btn {
  width: 100%;
}

/* 对方基础资料 */
.profile-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.profile-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #f7f5f0;
  border-radius: 16rpx;
  padding: 24rpx;
}

.profile-label {
  font-size: 32rpx;
  color: #5a5c5f;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.profile-value {
  font-size: 38rpx;
  font-weight: 600;
  color: #2b2d2f;
  text-align: right;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
